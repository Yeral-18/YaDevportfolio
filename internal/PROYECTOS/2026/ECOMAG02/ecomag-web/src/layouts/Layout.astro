---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title,
  description = 'ECOMAG S.A.S - Soluciones integrales en obra civil y gestion ambiental en Barrancabermeja, Santander. Certificados ISO 9001, ISO 14001 e ISO 45001.',
  ogImage = '/og-default.jpg',
  canonical,
} = Astro.props;

const siteUrl = 'https://ecomagsas.com';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL(ogImage, siteUrl).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'ECOMAG S.A.S',
  description,
  url: siteUrl,
  logo: `${siteUrl}/logo.png`,
  image: ogImageUrl,
  telephone: '+57 XXX XXX XXXX',
  email: 'info@ecomagsas.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Calle 72 # 19 - 42',
    addressLocality: 'Barrancabermeja',
    addressRegion: 'Santander',
    addressCountry: 'CO',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 7.0653,
    longitude: -73.8547,
  },
  openingHours: 'Mo-Fr 08:00-18:00',
  sameAs: [
    'https://www.facebook.com/ecomagsas',
    'https://www.instagram.com/ecomagsas',
    'https://www.linkedin.com/company/ecomagsas',
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Servicios de obra civil y gestion ambiental',
  },
};
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Google Search Console verification (replace with actual code) -->
    <!-- <meta name="google-site-verification" content="YOUR_VERIFICATION_CODE" /> -->

    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Preload hero image for LCP optimization -->
    <link rel="preload" as="image" href="/hero-bg.jpg" type="image/jpeg" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:site_name" content="ECOMAG S.A.S" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Google Analytics (uncomment and replace GA_MEASUREMENT_ID when ready)
    <script async src="https://www.googletagmanager.com/gtag/js?id=GA_MEASUREMENT_ID"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'GA_MEASUREMENT_ID');
    </script>
    -->
  </head>
  <body class="min-h-screen bg-light font-body text-dark antialiased">
    <slot />
  </body>
</html>
