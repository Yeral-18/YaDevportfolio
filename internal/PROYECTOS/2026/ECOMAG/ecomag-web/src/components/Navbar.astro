---
const navLinks = [
  { label: 'Inicio', href: '#inicio' },
  { label: 'Sobre Nosotros', href: '#sobre-nosotros' },
  { label: 'Servicios', href: '#servicios' },
  { label: 'Proyectos', href: '#proyectos' },
  { label: 'Contacto', href: '#contacto' },
];
---

<div
  id="navbar"
  class="sticky top-0 z-40 w-full bg-white/95 transition-shadow duration-300"
  role="navigation"
>
  <div class="section-container" aria-label="Navegacion principal">
    <div class="flex h-14 items-center justify-between sm:h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class="shrink-0">
        <img
          src="/logo.png"
          alt="ECOMAG S.A.S - Soluciones integrales en obra civil y gestion ambiental"
          class="h-10 w-auto sm:h-12 lg:h-16"
          width="180"
          height="64"
        />
      </a>

      <!-- Desktop nav links -->
      <ul class="hidden items-center gap-1 lg:flex" role="list">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="nav-link relative px-3 py-2 text-sm font-medium text-gray-700 transition-colors hover:text-primary"
            >
              {link.label}
              <span class="absolute inset-x-3 -bottom-0.5 h-0.5 origin-left scale-x-0 bg-primary transition-transform duration-300 hover:scale-x-0 group-[]:scale-x-100" aria-hidden="true"></span>
            </a>
          </li>
        ))}
      </ul>

      <!-- Desktop CTA -->
      <div class="hidden lg:block">
        <a href="#contacto" class="btn-primary">
          Cotizar
        </a>
      </div>

      <!-- Mobile menu button — min 44x44 touch target -->
      <button
        id="menu-toggle"
        type="button"
        class="inline-flex items-center justify-center rounded-lg p-2 min-w-[44px] min-h-[44px] text-gray-700 transition-colors hover:bg-gray-100 hover:text-primary lg:hidden"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Abrir menu de navegacion"
      >
        <svg id="icon-open" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg id="icon-close" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="fixed inset-y-0 right-0 z-50 hidden w-72 translate-x-full bg-white shadow-2xl transition-transform duration-300 ease-in-out lg:hidden"
    aria-label="Menu movil"
  >
    <div class="flex h-full flex-col px-6 pt-20 pb-6">
      <ul class="flex flex-col gap-1" role="list">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="mobile-nav-link block rounded-lg px-4 py-3 min-h-[44px] flex items-center text-base font-medium text-gray-700 transition-colors hover:bg-primary-50 hover:text-primary"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
      <div class="mt-6">
        <a href="#contacto" class="btn-primary w-full text-center mobile-nav-link">
          Cotizar
        </a>
      </div>
    </div>
  </div>

  <!-- Mobile menu backdrop -->
  <div
    id="mobile-backdrop"
    class="fixed inset-0 z-40 hidden bg-black/50 transition-opacity duration-300 lg:hidden"
    aria-hidden="true"
  ></div>
</div>

<style>
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0.75rem;
    right: 0.75rem;
    bottom: -2px;
    height: 2px;
    background-color: theme('colors.primary.DEFAULT');
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }

  .nav-link:hover::after {
    transform: scaleX(1);
  }

  #mobile-menu.is-open {
    display: block;
    transform: translateX(0);
  }

  #mobile-backdrop.is-open {
    display: block;
    opacity: 1;
  }
</style>

<script is:inline>
  (function () {
    const navbar = document.getElementById('navbar');
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const backdrop = document.getElementById('mobile-backdrop');
    const iconOpen = document.getElementById('icon-open');
    const iconClose = document.getElementById('icon-close');

    // Shadow on scroll
    let ticking = false;
    window.addEventListener('scroll', function () {
      if (!ticking) {
        window.requestAnimationFrame(function () {
          if (window.scrollY > 10) {
            navbar.classList.add('shadow-md', 'backdrop-blur-md');
            navbar.classList.remove('bg-white/95');
            navbar.classList.add('bg-white/90');
          } else {
            navbar.classList.remove('shadow-md', 'backdrop-blur-md');
            navbar.classList.remove('bg-white/90');
            navbar.classList.add('bg-white/95');
          }
          ticking = false;
        });
        ticking = true;
      }
    });

    // Mobile menu toggle
    function openMenu() {
      menu.classList.remove('hidden');
      backdrop.classList.remove('hidden');
      // Force reflow for transition
      void menu.offsetHeight;
      menu.classList.add('is-open');
      backdrop.classList.add('is-open');
      iconOpen.classList.add('hidden');
      iconClose.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      menu.classList.remove('is-open');
      backdrop.classList.remove('is-open');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      setTimeout(function () {
        menu.classList.add('hidden');
        backdrop.classList.add('hidden');
      }, 300);
    }

    toggle.addEventListener('click', function () {
      var isOpen = toggle.getAttribute('aria-expanded') === 'true';
      isOpen ? closeMenu() : openMenu();
    });

    backdrop.addEventListener('click', closeMenu);

    // Close mobile menu on nav link click
    var mobileLinks = menu.querySelectorAll('.mobile-nav-link');
    mobileLinks.forEach(function (link) {
      link.addEventListener('click', closeMenu);
    });

    // Close on Escape key
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
        closeMenu();
        toggle.focus();
      }
    });
  })();
</script>
