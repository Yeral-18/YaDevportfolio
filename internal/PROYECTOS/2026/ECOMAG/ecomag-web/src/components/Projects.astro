---
const projects = [
  {
    title: 'Construccion Via Terciaria',
    subtitle: 'Municipio de San Vicente',
    category: 'Obra Civil',
    description: 'Construccion y adecuacion de 12 km de via terciaria, mejorando la conectividad rural y el acceso a comunidades del municipio.',
    image: '/images/projects/via-terciaria.jpg',
    alt: 'Construccion de via terciaria en el municipio de San Vicente por ECOMAG S.A.S',
    large: true,
  },
  {
    title: 'Remediacion Ambiental',
    subtitle: 'Zona Industrial Barrancabermeja',
    category: 'Gestion Ambiental',
    description: 'Proceso integral de remediacion de suelos contaminados en zona industrial, restaurando condiciones ambientales optimas.',
    image: '/images/projects/remediacion.jpg',
    alt: 'Remediacion ambiental en zona industrial de Barrancabermeja por ECOMAG S.A.S',
    large: false,
  },
  {
    title: 'Mantenimiento Planta de Tratamiento',
    subtitle: 'Planta PTAR Municipal',
    category: 'Mantenimiento Industrial',
    description: 'Mantenimiento preventivo y correctivo de planta de tratamiento de aguas residuales, asegurando operatividad continua.',
    image: '/images/projects/planta-tratamiento.jpg',
    alt: 'Mantenimiento de planta de tratamiento de aguas residuales por ECOMAG S.A.S',
    large: false,
  },
  {
    title: 'Supervision Tecnica',
    subtitle: 'Proyecto Hidroelectrico',
    category: 'Ingenieria',
    description: 'Interventoria y supervision tecnica de proyecto hidroelectrico, garantizando cumplimiento de cronograma y especificaciones.',
    image: '/images/projects/hidroelectrico.jpg',
    alt: 'Supervision tecnica de proyecto hidroelectrico por ECOMAG S.A.S',
    large: true,
  },
];
---

<section id="proyectos" class="projects-section">
  <div class="section-container section-padding">
    <!-- Header -->
    <div class="mb-8 text-center sm:mb-12 md:mb-16">
      <span class="mb-3 inline-block text-xs font-semibold uppercase tracking-widest text-accent sm:mb-4">
        Proyectos Destacados
      </span>
      <h2 class="heading-primary mx-auto max-w-3xl text-[1.5rem] sm:text-3xl lg:text-5xl">
        Experiencia que genera confianza
      </h2>
    </div>

    <!-- Mobile: Vertical stack -->
    <div class="flex flex-col gap-5 md:hidden">
      {projects.map((project) => (
        <article class="project-card-mobile overflow-hidden rounded-xl shadow-lg">
          <div class="relative">
            <div class="aspect-[16/9] overflow-hidden">
              <img
                src={project.image}
                alt={project.alt}
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover"
              />
            </div>
            <!-- Overlay gradient -->
            <div class="absolute inset-0 bg-gradient-to-t from-[#0a2e12]/90 via-[#1B5E20]/30 to-transparent"></div>
            <!-- Content overlay -->
            <div class="absolute inset-x-0 bottom-0 p-4">
              <span class="mb-1.5 inline-block rounded-full bg-accent/90 px-2.5 py-0.5 text-[0.6875rem] font-semibold text-white">
                {project.category}
              </span>
              <h3 class="font-display text-base font-bold text-white">{project.title}</h3>
              <p class="text-xs text-white/80">{project.subtitle}</p>
            </div>
          </div>
          <!-- Description below image -->
          <div class="bg-white p-4">
            <p class="text-[0.8125rem] leading-relaxed text-gray-600">{project.description}</p>
          </div>
        </article>
      ))}
    </div>

    <!-- Desktop: Alternating masonry layout -->
    <div class="hidden gap-6 md:grid md:grid-cols-2" id="projects-desktop-grid">
      {projects.map((project, i) => (
        <article
          class={`project-card-desktop overflow-hidden rounded-2xl shadow-lg ${
            project.large ? 'row-span-1' : 'row-span-1'
          }`}
          data-index={i}
          data-category={project.category}
          style={`opacity: 0; transform: translate3d(${i % 2 === 0 ? '-80px' : '80px'}, 0, 0) rotate(${i % 2 === 0 ? '-3deg' : '3deg'}); will-change: transform, opacity;`}
        >
          <div class="group relative h-full">
            <div class={project.large ? 'aspect-[16/9]' : 'aspect-square'}>
              <img
                src={project.image}
                alt={project.alt}
                loading="lazy"
                decoding="async"
                class="project-desktop-img h-full w-full object-cover transition-transform duration-500 will-change-transform"
                style="transform: translate3d(0,0,0);"
              />
            </div>
            <!-- Overlay gradient -->
            <div class="project-overlay absolute inset-0 bg-gradient-to-t from-[#0a2e12]/85 via-[#1B5E20]/25 to-transparent opacity-80 transition-all duration-500"></div>
            <!-- Content -->
            <div class="project-content absolute inset-x-0 bottom-0 p-6 md:p-8 transition-transform duration-300">
              <span class="mb-3 inline-block rounded-full bg-accent/90 px-3 py-1 text-xs font-semibold text-white">
                {project.category}
              </span>
              <h3 class="mb-2 font-display text-xl font-bold text-white lg:text-2xl">
                {project.title}
              </h3>
              <p class="mb-1 text-sm font-medium text-white/90">{project.subtitle}</p>
              <p class="text-sm leading-relaxed text-white/70">{project.description}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .projects-section {
    background-color: #EDE5D8;
    background-image: linear-gradient(rgba(160,120,60,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(160,120,60,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  .project-card-desktop {
    position: relative;
    transition: none;
    overflow: hidden;
    z-index: 1;
  }

  .project-card-desktop.revealed {
    opacity: 1 !important;
    transform: translate3d(0, 0, 0) rotate(0deg) !important;
    transition: opacity 0.8s cubic-bezier(0.34, 1.56, 0.64, 1), transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .project-card-desktop.revealed:hover {
    z-index: 10;
    transform: translateY(-12px) scale(1.03) rotate(-1deg) !important;
    box-shadow: 0 35px 70px -15px rgba(0, 0, 0, 0.3);
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* Hover: image subtle zoom inside the card */
  .project-card-desktop .project-desktop-img {
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) !important;
  }

  .project-card-desktop .group:hover .project-desktop-img {
    transform: scale(1.08) !important;
  }

  /* Hover: overlay with warmer, more pleasant gradient */
  .project-card-desktop .group:hover .project-overlay {
    opacity: 1;
    background: linear-gradient(to top, rgba(27,94,32,0.85) 0%, rgba(27,94,32,0.3) 45%, transparent 100%);
  }

  /* Hover: content slides up */
  .project-card-desktop .project-content {
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .project-card-desktop .group:hover .project-content {
    transform: translate3d(0, -6px, 0);
  }

  /* Accent line at bottom via ::after */
  .project-card-desktop::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    z-index: 10;
    border-radius: 0 0 1rem 1rem;
  }

  .project-card-desktop[data-category="Obra Civil"]::after {
    background: var(--color-primary);
  }

  .project-card-desktop[data-category="Gestion Ambiental"]::after {
    background: var(--color-accent);
  }

  .project-card-desktop[data-category="Mantenimiento Industrial"]::after {
    background: var(--color-secondary);
  }

  .project-card-desktop[data-category="Ingenieria"]::after {
    background: #E65100;
  }

  .project-card-desktop:hover::after {
    transform: scaleX(1);
  }

  /* Mobile cards */
  .project-card-mobile {
    transition: transform 0.3s ease;
  }

  .project-card-mobile:active {
    transform: scale(0.98);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Desktop cards - dramatic alternating reveal
    const desktopGrid = document.getElementById('projects-desktop-grid');
    if (desktopGrid) {
      const cards = desktopGrid.querySelectorAll('.project-card-desktop');

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              cards.forEach((card) => {
                const index = parseInt(card.dataset.index || '0');
                const delay = index * 0.2;
                setTimeout(() => {
                  card.classList.add('revealed');
                }, delay * 1000);
              });
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 }
      );

      observer.observe(desktopGrid);
    }

  });
</script>
