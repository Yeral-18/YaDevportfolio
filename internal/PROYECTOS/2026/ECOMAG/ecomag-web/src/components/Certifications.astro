---
const certifications = [
  {
    name: 'ISO 9001:2015',
    description: 'Sistema de Gestion de Calidad',
  },
  {
    name: 'ISO 14001:2015',
    description: 'Sistema de Gestion Ambiental',
  },
  {
    name: 'ISO 45001:2018',
    description: 'Seguridad y Salud en el Trabajo',
  },
];
---

<section class="certifications-section relative overflow-hidden py-10 md:py-14" aria-label="Certificaciones">
  <div class="section-container">
    <div class="flex flex-col items-center gap-8">
      <!-- Badges row -->
      <div class="cert-badges-container flex flex-wrap items-center justify-center gap-6 md:gap-10" id="cert-badges">
        {certifications.map((cert, i) => (
          <div class="cert-badge flex items-center gap-3 rounded-xl bg-white px-5 py-4 shadow-sm" data-delay={i * 0.2} style={`opacity: 0; transform: translate3d(0, 40px, 0) rotate(-5deg) scale(0.9); will-change: transform, opacity;`}>
            <!-- Shield icon -->
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-primary-50 text-primary">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
              </svg>
            </div>
            <div>
              <p class="font-display text-sm font-bold text-dark md:text-base">{cert.name}</p>
              <p class="text-xs text-gray-500">{cert.description}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Bureau Veritas text -->
      <p class="text-center text-sm font-medium text-gray-600">
        Certificados por
        <span class="font-semibold text-primary">Bureau Veritas</span>
        &mdash; Vigentes hasta 2028
      </p>
    </div>
  </div>
</section>

<style>
  .certifications-section {
    background-color: #F5EFE4;
    background-image: repeating-linear-gradient(45deg, transparent, transparent 35px, rgba(180,140,60,0.04) 35px, rgba(180,140,60,0.04) 36px);
  }

  .cert-badge {
    transition: none;
  }

  .cert-badge.revealed {
    opacity: 1 !important;
    transform: translate3d(0, 0, 0) rotate(0deg) scale(1) !important;
    transition: opacity 0.6s cubic-bezier(0.34, 1.56, 0.64, 1), transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .cert-badge.revealed:hover {
    transform: translate3d(0, -10px, 0) scale(1.08) !important;
    box-shadow: 0 16px 40px -8px rgba(27, 94, 32, 0.35), 0 0 0 2px rgba(27, 94, 32, 0.15);
    background: linear-gradient(135deg, #ffffff 0%, rgba(27, 94, 32, 0.04) 100%);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('cert-badges');
    if (!container) return;

    const badges = container.querySelectorAll('.cert-badge');

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            badges.forEach((badge) => {
              const delay = parseFloat(badge.dataset.delay || '0');
              setTimeout(() => {
                badge.classList.add('revealed');
              }, delay * 1000);
            });
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2 }
    );

    observer.observe(container);
  });
</script>
