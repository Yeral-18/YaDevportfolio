---

<div class="bg-primary-900 text-white">
  <div class="section-container">
    <div class="flex items-center justify-between py-1.5 text-xs sm:text-sm">
      <!-- Contact info -->
      <div class="flex items-center gap-2 sm:gap-4 min-w-0">
        <a
          href="tel:+57XXXXXXXXXX"
          class="flex items-center gap-1.5 min-h-[44px] sm:min-h-0 transition-colors hover:text-accent-200"
        >
          <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          <span class="hidden [@media(min-width:380px)]:inline">+57 XXX XXX XXXX</span>
        </a>

        <span class="hidden text-primary-300 sm:inline" aria-hidden="true">|</span>

        <a
          href="mailto:info@ecomagsas.com"
          class="flex items-center gap-1.5 min-h-[44px] sm:min-h-0 transition-colors hover:text-accent-200"
        >
          <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          <span class="hidden sm:inline">info@ecomagsas.com</span>
        </a>

        <span class="hidden text-primary-300 md:inline" aria-hidden="true">|</span>

        <span class="hidden items-center gap-1.5 md:flex">
          <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>Lun-Vie 8:00-18:00</span>
        </span>
      </div>

      <!-- Social links -->
      <nav class="flex items-center gap-1 sm:gap-3" aria-label="Redes sociales">
        {socialLinks.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Visitar ${social.name}`}
            class="flex items-center justify-center min-w-[44px] min-h-[44px] sm:min-w-0 sm:min-h-0 text-white/80 transition-colors hover:text-accent-200"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <Fragment set:html={social.icon} />
            </svg>
          </a>
        ))}
      </nav>
    </div>
  </div>
</div>
