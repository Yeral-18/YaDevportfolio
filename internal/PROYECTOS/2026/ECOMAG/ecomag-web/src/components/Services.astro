---

<section id="servicios" class="services-section">
  <div class="section-container section-padding">
    <!-- Header -->
    <div class="mb-8 text-center sm:mb-12 md:mb-16">
      <span class="mb-3 inline-block text-xs font-semibold uppercase tracking-widest text-accent sm:mb-4">
        Nuestros Servicios
      </span>
      <h2 class="heading-primary mx-auto max-w-3xl text-[1.5rem] sm:text-3xl lg:text-5xl">
        Soluciones integrales para cada desafio
      </h2>
    </div>

    <!-- Services grid -->
    <div class="services-grid grid gap-5 sm:grid-cols-2 sm:gap-8 lg:grid-cols-3" id="services-grid">
      {services.map((service, i) => (
        <div class="service-card group overflow-hidden rounded-xl sm:rounded-2xl bg-white shadow-md" data-delay={i * 0.12} style={`opacity: 0; transform: translate3d(0, 60px, 0) rotate(2deg); will-change: transform, opacity;`}>
          <!-- Image with hover animation -->
          <div class="service-image-wrapper relative aspect-[16/10] sm:aspect-[4/3] overflow-hidden">
            <img
              src={service.image}
              alt={service.alt}
              loading="lazy"
              decoding="async"
              class="service-hover-image h-full w-full object-cover will-change-transform"
              style="transform: translate3d(0,0,0);"
            />
            <!-- Color overlay on hover -->
            <div class="service-color-overlay absolute inset-0 pointer-events-none" aria-hidden="true"></div>
            <!-- Icon overlay -->
            <div class="service-icon-overlay absolute bottom-3 right-3 flex h-10 w-10 items-center justify-center rounded-full bg-primary text-white shadow-lg" data-icon-delay={i * 0.12 + 0.4} style="transform: scale(0); will-change: transform;">
              <Fragment set:html={service.icon} />
            </div>
          </div>

          <!-- Content -->
          <div class="p-4 sm:p-6">
            <h3 class="mb-2 font-display text-base sm:text-lg font-semibold text-dark">{service.title}</h3>
            <p class="mb-3 text-sm leading-relaxed text-gray-600 sm:mb-4">{service.description}</p>
            <a
              href={`#contacto`}
              class="group/link inline-flex items-center gap-1 text-sm font-semibold text-primary transition-colors hover:text-primary-700 min-h-[44px] py-2"
            >
              Conocer mas
              <span class="inline-block transition-transform duration-300 group-hover/link:translate-x-1">&rarr;</span>
              <span class="block h-0.5 max-w-0 bg-primary transition-all duration-300 group-hover/link:max-w-full"></span>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services-section {
    background-color: #E0EBD8;
    background-image: radial-gradient(circle at 20% 80%, rgba(27,94,32,0.05) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(124,179,66,0.05) 0%, transparent 50%);
  }

  .service-card {
    transition: none;
    border-left: 3px solid transparent;
  }

  .service-card.revealed {
    opacity: 1 !important;
    transform: translate3d(0, 0, 0) rotate(0deg) !important;
    transition: opacity 0.7s cubic-bezier(0.34, 1.56, 0.64, 1),
                transform 0.7s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.5s cubic-bezier(0.34, 1.56, 0.64, 1),
                border-color 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .service-card.revealed:hover {
    transform: translateY(-12px) !important;
    box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.2);
    border-left-color: var(--color-primary, #1b5e20);
  }

  /* Disable hover lift on touch devices to prevent sticky hover states */
  @media (hover: none) {
    .service-card.revealed:hover {
      transform: translate3d(0, 0, 0) rotate(0deg) !important;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }
  }

  /* Image hover floating animation */
  .service-hover-image {
    transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1), filter 0.5s ease-out;
  }

  @keyframes serviceImageFloat {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1.02); }
    25% { transform: translate3d(6px, -4px, 0) scale(1.04); }
    50% { transform: translate3d(-4px, -7px, 0) scale(1.03); }
    75% { transform: translate3d(8px, -2px, 0) scale(1.05); }
  }

  .service-card:hover .service-hover-image {
    animation: serviceImageFloat 5s ease-in-out infinite;
    filter: brightness(1.08);
  }

  /* Color overlay that fades in on hover */
  .service-color-overlay {
    background: linear-gradient(to bottom, transparent 0%, rgba(27,94,32,0.15) 100%);
    opacity: 0;
    transition: opacity 0.5s ease-out;
  }

  .service-card:hover .service-color-overlay {
    opacity: 1;
  }

  .service-icon-overlay {
    transition: none;
  }

  .service-card.revealed .service-icon-overlay {
    transform: scale(1) !important;
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const grid = document.getElementById('services-grid');
    if (!grid) return;

    const cards = grid.querySelectorAll('.service-card');

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            cards.forEach((card) => {
              const delay = parseFloat(card.dataset.delay || '0');
              const iconOverlay = card.querySelector('.service-icon-overlay');
              const iconDelay = parseFloat(iconOverlay?.dataset.iconDelay || '0');

              setTimeout(() => {
                card.classList.add('revealed');
              }, delay * 1000);

              if (iconOverlay) {
                setTimeout(() => {
                  iconOverlay.style.transitionDelay = '0s';
                }, iconDelay * 1000);
              }
            });
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );

    observer.observe(grid);
  });
</script>
