---
const benefits = [
  {
    title: 'Solución Integral en un Solo Proveedor',
    description: 'En Barrancabermeja y Santander, ofrecemos todos los servicios que necesita en un solo lugar: transporte de carga, obras civiles, remediación ambiental, izaje de cargas pesadas y transición energética.',
    icon: `<svg width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <circle cx="12" cy="12" r="3" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v3m0 12v3M3 12h3m12 0h3M5.636 5.636l2.122 2.122m8.484 8.484l2.122 2.122M5.636 18.364l2.122-2.122m8.484-8.484l2.122-2.122" />
    </svg>`,
  },
  {
    title: 'Calidad Certificada ISO en Cada Proyecto',
    description: 'Trabajamos bajo los más altos estándares internacionales con certificaciones ISO 9001, ISO 14001 e ISO 45001, garantizando excelencia en cada obra civil, transporte y operación ambiental en Colombia.',
    icon: `<svg width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 2l2.09 4.26L19 7.27l-3.5 3.41.82 4.82L12 13.4l-4.32 2.1.82-4.82L5 7.27l4.91-1.01L12 2z" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 22l3-2 3 2" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 20v-4" />
    </svg>`,
  },
  {
    title: 'Líderes en Transición Energética',
    description: 'Lideramos la instalación de paneles solares fotovoltaicos y prácticas sostenibles en Barrancabermeja y el Magdalena Medio, contribuyendo al desarrollo de energía renovable en Colombia.',
    icon: `<svg width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <circle cx="12" cy="6" r="4" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 2v-1M12 11v1M8.5 3.5L7.8 2.8M16.2 9.2l-.7.7M8 6H7M17 6h1M8.5 8.5l-.7.7M16.2 2.8l-.7.7" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 14c0 0-2 1-2 3s2 4 8 4 8-2 8-4-2-3-2-3" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 16c1 1 2 1.5 3 1.5s2-.5 3-1.5" />
    </svg>`,
  },
];
---

<section id="beneficios" class="benefits-section">
  <div class="benefits-container">
    <!-- Header -->
    <div class="benefits-header">
      <span class="benefits-label">
        <span class="benefits-label__line" aria-hidden="true"></span>
        <span class="benefits-label__text">¿POR QUÉ ELEGIRNOS?</span>
      </span>
      <h2 class="benefits-heading">
        Razones para Confiar en<br />Multiservicios P&J en Barrancabermeja
      </h2>
      <p class="benefits-description">
        Más de una década de experiencia en Santander respaldan nuestro compromiso
        con la excelencia en obras civiles, transporte de carga y remediación
        ambiental en cada proyecto.
      </p>
    </div>

    <!-- Cards Grid -->
    <div class="benefits-grid">
      {benefits.map((benefit, i) => (
        <div class="benefit-card" data-benefit-index={i} style="opacity: 0;">
          <div class="benefit-icon-wrapper">
            <Fragment set:html={benefit.icon} />
          </div>
          <h3 class="benefit-title">{benefit.title}</h3>
          <p class="benefit-desc">{benefit.description}</p>
          <div class="benefit-accent-line" aria-hidden="true"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .benefits-section {
    background-color: #f8fafb;
    position: relative;
    overflow: hidden;
  }

  .benefits-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem 1.25rem;
  }

  @media (min-width: 640px) {
    .benefits-container {
      padding: 6rem 2rem;
    }
  }

  @media (min-width: 1024px) {
    .benefits-container {
      padding: 7rem 2rem;
    }
  }

  /* Header */
  .benefits-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 3.5rem;
  }

  @media (min-width: 1024px) {
    .benefits-header {
      margin-bottom: 4.5rem;
    }
  }

  .benefits-label {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
  }

  .benefits-label__line {
    display: block;
    width: 2rem;
    height: 2px;
    border-radius: 1px;
    background-color: #8CC63F;
  }

  .benefits-label__text {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #0089D0;
    line-height: 1;
  }

  .benefits-heading {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.15;
    color: #005B32;
    margin-top: 1rem;
    letter-spacing: -0.02em;
  }

  @media (min-width: 640px) {
    .benefits-heading {
      font-size: 2.5rem;
    }
  }

  @media (min-width: 1024px) {
    .benefits-heading {
      font-size: 3rem;
    }
  }

  .benefits-description {
    font-size: 1rem;
    line-height: 1.7;
    color: #607D8B;
    margin-top: 1rem;
  }

  /* Grid */
  .benefits-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .benefits-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  /* Card */
  .benefit-card {
    background: #ffffff;
    border-radius: 1rem;
    padding: 2rem 1.75rem 2.25rem;
    position: relative;
    border: 1px solid rgba(0, 137, 208, 0.08);
    transition: transform 0.35s cubic-bezier(0.34, 1.3, 0.64, 1),
                box-shadow 0.35s ease;
    will-change: transform;
  }

  .benefit-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px -8px rgba(0, 91, 50, 0.12),
                0 4px 16px -4px rgba(0, 137, 208, 0.08);
  }

  /* Icon */
  .benefit-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, rgba(0, 137, 208, 0.08), rgba(140, 198, 63, 0.1));
    color: #0089D0;
    margin-bottom: 1.25rem;
    transition: background 0.3s ease;
  }

  .benefit-card:hover .benefit-icon-wrapper {
    background: linear-gradient(135deg, rgba(0, 137, 208, 0.14), rgba(140, 198, 63, 0.16));
  }

  /* Title */
  .benefit-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: #005B32;
    line-height: 1.35;
    margin-bottom: 0.75rem;
  }

  @media (min-width: 1024px) {
    .benefit-title {
      font-size: 1.25rem;
    }
  }

  /* Description */
  .benefit-desc {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: #607D8B;
  }

  /* Accent line */
  .benefit-accent-line {
    margin-top: 1.5rem;
    width: 2.5rem;
    height: 3px;
    border-radius: 2px;
    background: linear-gradient(90deg, #0089D0, #8CC63F);
    transition: width 0.35s ease;
  }

  .benefit-card:hover .benefit-accent-line {
    width: 4rem;
  }

  /* Reveal animation */
  .benefit-card.revealed {
    opacity: 1 !important;
    transform: translate3d(0, 0, 0) !important;
    transition: opacity 0.6s cubic-bezier(0, 0, 0.2, 1),
                transform 0.6s cubic-bezier(0, 0, 0.2, 1);
  }

  .benefit-card:not(.revealed) {
    transform: translate3d(0, 30px, 0);
  }

  /* Hover still applies after reveal */
  .benefit-card.revealed:hover {
    transform: translateY(-4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .benefit-card {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }

  @media (hover: none) {
    .benefit-card:hover {
      transform: none;
      box-shadow: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll<HTMLElement>('.benefit-card');
    if (!cards.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const card = entry.target as HTMLElement;
            const index = parseInt(card.dataset.benefitIndex || '0', 10);
            setTimeout(() => {
              card.classList.add('revealed');
            }, index * 150);
            observer.unobserve(card);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
    );

    cards.forEach((card) => observer.observe(card));
  });
</script>
