---
/**
 * Topbar - Slim contact info bar
 * MULTISERVICIOS P&J S.A.S
 * Dark background strip with contact details and location
 */
---

<div class="topbar hidden md:block bg-[#263238] text-white/80 text-xs tracking-wide">
  <div class="section-container flex items-center justify-between py-2">
    <!-- Contact Info -->
    <div class="flex items-center gap-6">
      <!-- Phone -->
      <a
        href="tel:+573204464553"
        class="flex items-center gap-2 hover:text-[#8AD7F8] transition-colors duration-200"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-3.5 h-3.5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
          ></path>
        </svg>
        <span>+57 320 4464553</span>
      </a>

      <!-- Divider -->
      <span class="w-px h-3 bg-white/20"></span>

      <!-- Email -->
      <a
        href="mailto:multiserviciospjsas@gmail.com"
        class="flex items-center gap-2 hover:text-[#8AD7F8] transition-colors duration-200"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-3.5 h-3.5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect width="20" height="16" x="2" y="4" rx="2"></rect>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
        </svg>
        <span>multiserviciospjsas@gmail.com</span>
      </a>
    </div>

    <!-- Location -->
    <div class="flex items-center gap-2 text-white/60">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-3.5 h-3.5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
        <circle cx="12" cy="10" r="3"></circle>
      </svg>
      <span>Barrancabermeja, Corregimiento El Llanito</span>
    </div>
  </div>
</div>
