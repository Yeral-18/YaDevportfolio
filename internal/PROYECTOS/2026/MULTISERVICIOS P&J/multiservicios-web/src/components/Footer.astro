---
/**
 * Footer — Premium Awwwards-level design
 * MULTISERVICIOS P&J S.A.S
 * CTA Banner + 3-column grid + Certification bar + Copyright
 */

const services = [
  { label: "Transporte de Carga", href: "#servicios" },
  { label: "Obras Civiles", href: "#servicios" },
  { label: "Movimiento de Carga - Izaje", href: "#servicios" },
  { label: "Remediación Ambiental", href: "#servicios" },
  { label: "Transición Energética", href: "#servicios" },
  { label: "Alquiler de Maquinaria", href: "#servicios" },
];

const socialLinks = [
  {
    label: "Facebook",
    href: "#",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
  },
  {
    label: "Instagram",
    href: "#",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>`,
  },
  {
    label: "LinkedIn",
    href: "#",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: "WhatsApp",
    href: "https://wa.me/573204464553",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`,
  },
];

const certifications = [
  { label: "ISO 9001:2015", title: "Sistema de Gestión de Calidad" },
  { label: "ISO 14001:2015", title: "Sistema de Gestión Ambiental" },
  { label: "ISO 45001:2018", title: "Seguridad y Salud en el Trabajo" },
];

const basePath = import.meta.env.BASE_URL ?? "/multiservicios/";
---

<!-- Section 1: CTA Banner -->
<section class="cta-banner-wrapper">
  <div class="section-container">
    <div class="cta-banner">
      <div class="cta-pattern"></div>
      <img
        src={`${basePath}logo-white.png`}
        alt=""
        aria-hidden="true"
        class="cta-watermark"
      />
      <div class="cta-content">
        <h2 class="cta-heading">
          &iquest;Listo para su pr&oacute;ximo proyecto?
        </h2>
        <p class="cta-subtitle">
          Cont&aacute;ctenos hoy para una cotizaci&oacute;n sin compromiso
        </p>
        <a href="#contacto" class="cta-button">
          <svg xmlns="http://www.w3.org/2000/svg" class="cta-btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
          Solicitar Cotizaci&oacute;n
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Section 2: Main Footer Content -->
<footer class="footer-main">
  <div class="section-container footer-grid-container">
    <div class="footer-grid">

      <!-- Column 1: Brand -->
      <div class="footer-brand">
        <a href="#inicio" class="footer-logo-link">
          <img
            src={`${basePath}logo-white.png`}
            alt="Multiservicios P&J S.A.S - Servicios integrales en Barrancabermeja"
            class="footer-logo-img"
            loading="lazy"
            width="160"
            height="48"
          />
        </a>
        <p class="footer-tagline">
          Empresa de ingenier&iacute;a en Barrancabermeja, Santander. Soluciones integrales en transporte de carga, obras civiles, remediaci&oacute;n ambiental y transici&oacute;n energ&eacute;tica en Colombia.
        </p>
        <div class="footer-social">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              aria-label={social.label}
              class="footer-social-icon"
              target={social.href.startsWith("http") ? "_blank" : undefined}
              rel={social.href.startsWith("http") ? "noopener" : undefined}
              set:html={social.icon}
            />
          ))}
        </div>
      </div>

      <!-- Column 2: Servicios -->
      <nav class="footer-services" aria-label="Servicios de Multiservicios P&J">
        <h4 class="footer-heading">Servicios</h4>
        <ul class="footer-services-list">
          {services.map((service) => (
            <li>
              <a href={service.href} class="footer-link">
                <span class="footer-link-arrow">&rsaquo;</span>
                {service.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Column 3: Contacto -->
      <div class="footer-contact">
        <h4 class="footer-heading">Contacto</h4>
        <ul class="footer-contact-list">
          <li class="footer-contact-item">
            <span class="footer-contact-icon-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" class="footer-contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </span>
            <span>Corregimiento El Llanito, Barrancabermeja, Santander, Colombia</span>
          </li>
          <li class="footer-contact-item">
            <span class="footer-contact-icon-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" class="footer-contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </span>
            <a href="tel:+573204464553" class="footer-contact-link">+57 320 4464553</a>
          </li>
          <li class="footer-contact-item">
            <span class="footer-contact-icon-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" class="footer-contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </span>
            <a href="mailto:gerencia@multiserviciospj.com" class="footer-contact-link">gerencia@multiserviciospj.com</a>
          </li>
          <li class="footer-contact-item">
            <span class="footer-contact-icon-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" class="footer-contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <line x1="2" y1="12" x2="22" y2="12"/>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
            </span>
            <a href="https://www.multiserviciospj.com" class="footer-contact-link" target="_blank" rel="noopener">www.multiserviciospj.com</a>
          </li>
        </ul>
      </div>

      <!-- Column 4: Certificaciones -->
      <div class="footer-certs-col">
        <h4 class="footer-heading">Certificaciones</h4>
        <img
          src={`${basePath}images/bureau-veritas-iso.png`}
          alt="Certificación Bureau Veritas - ISO 9001:2015, ISO 14001:2015, ISO 45001:2018"
          class="footer-cert-img"
          loading="lazy"
          width="240"
          height="80"
        />
      </div>

    </div>
  </div>

  <!-- Section 4: Copyright Bar -->
  <div class="footer-copyright-bar">
    <div class="section-container footer-copyright-inner">
      <p class="footer-copyright-text">
        &copy; 2026 MULTISERVICIOS P&amp;J S.A.S. Todos los derechos reservados.
      </p>
      <p class="footer-made-text">
        Hecho con &#10084; en Colombia
      </p>
    </div>
  </div>
</footer>

<style>
  /* ============================================================
     SECTION 1: CTA BANNER
     ============================================================ */
  .cta-banner-wrapper {
    position: relative;
    z-index: 2;
    padding: 0 1rem;
    margin-bottom: -3rem;
  }

  .cta-banner {
    position: relative;
    background: linear-gradient(135deg, #0089D0 0%, #006BA3 100%);
    border-radius: 1.25rem;
    padding: 3rem 2rem;
    overflow: hidden;
    max-width: 72rem;
    margin: 0 auto;
  }

  .cta-watermark {
    position: absolute;
    left: -30px;
    top: 50%;
    transform: translateY(-50%);
    height: 140px;
    width: auto;
    opacity: 0.05;
    mix-blend-mode: screen;
    filter: grayscale(1) brightness(2);
    pointer-events: none;
    z-index: 0;
  }

  .cta-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.06;
    background-image:
      radial-gradient(circle at 20% 30%, white 1px, transparent 1px),
      radial-gradient(circle at 80% 70%, white 1px, transparent 1px),
      radial-gradient(circle at 50% 50%, white 1.5px, transparent 1.5px);
    background-size: 60px 60px, 80px 80px, 100px 100px;
    pointer-events: none;
  }

  .cta-content {
    position: relative;
    z-index: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .cta-heading {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.75rem;
    font-weight: 800;
    color: white;
    line-height: 1.2;
    letter-spacing: -0.025em;
  }

  .cta-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.8);
    max-width: 28rem;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
    padding: 0.875rem 2.25rem;
    background: white;
    color: #006BA3;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    border-radius: 0.75rem;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  }

  .cta-button:hover {
    background: #f0f9ff;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.2);
  }

  .cta-btn-icon {
    width: 1.125rem;
    height: 1.125rem;
  }

  @media (max-width: 640px) {
    .cta-banner { padding: 2.5rem 1.25rem; }
    .cta-heading { font-size: 1.5rem; }
    .cta-button {
      width: 100%;
      justify-content: center;
      min-height: 48px;
    }
  }

  @media (min-width: 768px) {
    .cta-banner { padding: 3.5rem 3rem; }
    .cta-heading { font-size: 2.25rem; }
    .cta-subtitle { font-size: 1.125rem; }
  }

  /* ============================================================
     SECTION 2: MAIN FOOTER
     ============================================================ */
  .footer-main {
    background: #1a1a2e;
    color: white;
    padding-top: 5rem;
  }

  .footer-grid-container {
    padding-bottom: 3.5rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1.4fr 1fr 1.1fr 1fr;
      gap: 3rem;
    }
  }

  /* --- Brand Column --- */
  .footer-brand {
    grid-column: 1 / -1;
  }

  @media (min-width: 1024px) {
    .footer-brand {
      grid-column: auto;
    }
  }

  .footer-logo-link {
    display: inline-block;
    margin-bottom: 1.25rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .footer-logo-link:hover {
    opacity: 0.85;
  }

  .footer-logo-img {
    width: 160px;
    height: auto;
    object-fit: contain;
  }

  .footer-tagline {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.75;
    max-width: 22rem;
    margin-bottom: 1.5rem;
  }

  .footer-social {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.5);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
  }

  .footer-social-icon:hover {
    background: rgba(0, 137, 208, 0.15);
    border-color: rgba(0, 137, 208, 0.4);
    color: #0089D0;
    transform: translateY(-2px);
  }

  /* --- Servicios Column --- */
  .footer-heading {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 1.5rem;
    position: relative;
    padding-bottom: 0.75rem;
  }

  .footer-heading::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 1.5rem;
    height: 2px;
    background: #0089D0;
    border-radius: 1px;
  }

  .footer-services-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-link {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: all 0.25s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    line-height: 1.5;
  }

  .footer-link-arrow {
    color: rgba(255, 255, 255, 0.2);
    font-size: 1rem;
    transition: all 0.25s ease;
    transform: translateX(0);
  }

  .footer-link:hover {
    color: white;
  }

  .footer-link:hover .footer-link-arrow {
    color: #8CC63F;
    transform: translateX(3px);
  }

  /* --- Contact Column --- */
  .footer-contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-contact-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.6;
  }

  .footer-contact-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    min-width: 2rem;
    border-radius: 0.5rem;
    background: rgba(0, 137, 208, 0.08);
    margin-top: 0.05rem;
  }

  .footer-contact-icon {
    width: 0.875rem;
    height: 0.875rem;
    color: #0089D0;
    flex-shrink: 0;
  }

  .footer-contact-link {
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    transition: all 0.25s ease;
    position: relative;
  }

  .footer-contact-link:hover {
    color: white;
  }

  .footer-contact-link::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 0;
    height: 1px;
    background: #8CC63F;
    transition: width 0.3s ease;
  }

  .footer-contact-link:hover::after {
    width: 100%;
  }

  .footer-contact-item a {
    word-break: break-all;
  }

  @media (max-width: 480px) {
    .footer-services-list {
      gap: 0.5rem;
    }
  }

  /* ============================================================
     CERTIFICATIONS — Column in footer grid
     ============================================================ */
  .footer-certs-col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-cert-img {
    width: 100%;
    max-width: 280px;
    height: auto;
    border-radius: 10px;
    image-rendering: -webkit-optimize-contrast;
  }

  /* ============================================================
     SECTION 4: COPYRIGHT BAR
     ============================================================ */
  .footer-copyright-bar {
    background: #111122;
  }

  .footer-copyright-inner {
    padding-top: 1.125rem;
    padding-bottom: 1.125rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
  }

  @media (min-width: 640px) {
    .footer-copyright-inner {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-copyright-text {
    font-family: 'Inter', sans-serif;
    font-size: 0.725rem;
    color: rgba(255, 255, 255, 0.3);
    text-align: center;
    letter-spacing: 0.01em;
  }

  @media (min-width: 640px) {
    .footer-copyright-text {
      text-align: left;
    }
  }

  .footer-made-text {
    font-family: 'Inter', sans-serif;
    font-size: 0.725rem;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.01em;
  }
</style>
