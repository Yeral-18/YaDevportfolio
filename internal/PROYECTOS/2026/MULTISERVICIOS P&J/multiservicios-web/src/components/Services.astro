---

<section id="servicios" class="services-section">
  <!-- Logo watermark -->
  <img
    src={`${import.meta.env.BASE_URL ?? '/'}logo.png`}
    alt=""
    aria-hidden="true"
    class="services-watermark"
    loading="lazy"
  />
  <div class="services-container">
    <!-- Header - Left aligned -->
    <div class="services-header">
      <span class="services-label">
        <span class="services-label__line" aria-hidden="true"></span>
        <span class="services-label__text">NUESTROS SERVICIOS</span>
      </span>
      <h2 class="services-heading">
        Servicios Integrales de Ingeniería<br />en Barrancabermeja y Colombia
      </h2>
      <p class="services-description">
        Ofrecemos un portafolio completo de servicios de transporte de carga,
        obras civiles, remediación ambiental y transición energética en Santander.
        Calidad, seguridad y sostenibilidad certificadas bajo ISO 9001, ISO 14001
        e ISO 45001.
      </p>
    </div>

    <!-- Zigzag Service Rows -->
    <div class="services-rows">
      {services.map((service, i) => {
        const isEven = i % 2 === 1;
        const direction = isEven ? 'row-reverse' : 'row-normal';
        const slideFrom = isEven ? 'slide-from-right' : 'slide-from-left';
        return (
          <div
            class={`service-row ${direction} ${slideFrom}`}
            data-index={i}
            style="opacity: 0; will-change: transform, opacity;"
          >
            {/* Visual side */}
            <div class="service-visual-side">
              <div class="service-image-card">
                <img
                  src={`${import.meta.env.BASE_URL ?? '/multiservicios/'}${service.image.replace(/^\//, '')}`}
                  alt={`${service.title} - Multiservicios P&J Barrancabermeja`}
                  class="service-image"
                  loading="lazy"
                  width="400"
                  height="300"
                />
                <div class="service-image-overlay" aria-hidden="true"></div>
                <div class="service-image-icon-pill">
                  <Fragment set:html={service.icon} />
                </div>
              </div>
            </div>

            {/* Text side */}
            <div class="service-text-side">
              <span class="service-number">{service.number}</span>
              <h3 class="service-title">{service.title}</h3>
              <p class="service-desc">{service.description}</p>
              <a href="#contacto" class="service-link" aria-label={`Solicitar cotización de ${service.title}`}>
                Solicitar cotización
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </a>
            </div>

            {/* Divider */}
            {i < services.length - 1 && (
              <div class="row-divider" aria-hidden="true" />
            )}
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  /* Section */
  .services-section {
    background-color: #ffffff;
    position: relative;
    overflow: hidden;
  }

  .services-watermark {
    position: absolute;
    right: -20px;
    bottom: 10%;
    height: 200px;
    opacity: 0.04;
    mix-blend-mode: multiply;
    filter: grayscale(1);
    pointer-events: none;
    z-index: 0;
  }

  .services-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem 1.25rem;
  }

  @media (min-width: 640px) {
    .services-container {
      padding: 6rem 2rem;
    }
  }

  @media (min-width: 1024px) {
    .services-container {
      padding: 7rem 2rem;
    }
  }

  /* Header - Left aligned */
  .services-header {
    max-width: 560px;
    margin-bottom: 4rem;
  }

  @media (min-width: 1024px) {
    .services-header {
      margin-bottom: 5rem;
    }
  }

  .services-label {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
  }

  .services-label__line {
    display: block;
    width: 2rem;
    height: 2px;
    border-radius: 1px;
    background-color: #8CC63F;
  }

  .services-label__text {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #0089D0;
    line-height: 1;
  }

  .services-heading {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.15;
    color: #005B32;
    margin-top: 1rem;
    letter-spacing: -0.02em;
  }

  @media (min-width: 640px) {
    .services-heading {
      font-size: 2.5rem;
    }
  }

  @media (min-width: 1024px) {
    .services-heading {
      font-size: 3rem;
    }
  }

  .services-description {
    font-size: 1rem;
    line-height: 1.7;
    color: #607D8B;
    margin-top: 1rem;
  }

  /* Service Rows */
  .services-rows {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .service-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    padding: 2.5rem 0;
    position: relative;
  }

  @media (min-width: 768px) {
    .service-row {
      flex-direction: row;
      gap: 3rem;
      padding: 3.5rem 0;
    }

    .service-row.row-reverse {
      flex-direction: row-reverse;
    }

    .service-row.row-normal {
      flex-direction: row;
    }
  }

  @media (min-width: 1024px) {
    .service-row {
      gap: 4rem;
      padding: 4rem 0;
    }
  }

  /* Divider between rows */
  .row-divider {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    max-width: 800px;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(0, 137, 208, 0.15) 20%,
      rgba(0, 137, 208, 0.15) 80%,
      transparent 100%
    );
  }

  /* Visual Side */
  .service-visual-side {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .service-visual-side {
      width: 40%;
      flex-shrink: 0;
    }
  }

  /* Image Card */
  .service-image-card {
    position: relative;
    width: 100%;
    max-width: 400px;
    aspect-ratio: 4 / 3;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.2);
    transition: transform 0.4s cubic-bezier(0.34, 1.3, 0.64, 1),
                box-shadow 0.4s ease;
  }

  .service-row:hover .service-image-card {
    transform: scale(1.02);
    box-shadow: 0 20px 60px -15px rgba(0, 0, 0, 0.3);
  }

  .service-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .service-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 40%,
      rgba(0, 0, 0, 0.45) 100%
    );
    pointer-events: none;
  }

  .service-image-icon-pill {
    position: absolute;
    bottom: 0.75rem;
    left: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.95);
    color: #0089D0;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    backdrop-filter: blur(4px);
    z-index: 2;
  }

  /* Text Side */
  .service-text-side {
    width: 100%;
    text-align: center;
  }

  @media (min-width: 768px) {
    .service-text-side {
      width: 60%;
      text-align: left;
    }
  }

  .service-number {
    display: block;
    font-size: 3.5rem;
    font-weight: 800;
    color: rgba(0, 91, 50, 0.06);
    line-height: 1;
    letter-spacing: -0.04em;
    margin-bottom: 0.25rem;
    user-select: none;
  }

  @media (min-width: 640px) {
    .service-number {
      font-size: 4.5rem;
    }
  }

  .service-title {
    font-size: 1.375rem;
    font-weight: 700;
    color: #005B32;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  @media (min-width: 640px) {
    .service-title {
      font-size: 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .service-title {
      font-size: 1.75rem;
    }
  }

  .service-desc {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: #607D8B;
    max-width: 480px;
  }

  @media (max-width: 767px) {
    .service-desc {
      margin-left: auto;
      margin-right: auto;
    }
  }

  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    margin-top: 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #0089D0;
    text-decoration: none;
    transition: color 0.2s ease, gap 0.3s ease;
  }

  .service-link:hover {
    color: #0089D0;
    gap: 0.625rem;
  }

  .service-link svg {
    transition: transform 0.3s ease;
  }

  .service-link:hover svg {
    transform: translateX(3px);
  }

  /* Scroll Reveal Animations */
  .service-row.slide-from-left.revealed {
    opacity: 1 !important;
    transform: translate3d(0, 0, 0) !important;
    transition: opacity 0.7s cubic-bezier(0, 0, 0.2, 1),
                transform 0.7s cubic-bezier(0, 0, 0.2, 1);
  }

  .service-row.slide-from-right.revealed {
    opacity: 1 !important;
    transform: translate3d(0, 0, 0) !important;
    transition: opacity 0.7s cubic-bezier(0, 0, 0.2, 1),
                transform 0.7s cubic-bezier(0, 0, 0.2, 1);
  }

  .service-row.slide-from-left:not(.revealed) {
    transform: translate3d(-40px, 20px, 0);
  }

  .service-row.slide-from-right:not(.revealed) {
    transform: translate3d(40px, 20px, 0);
  }

  /* On mobile, only use vertical slide to prevent horizontal overflow */
  @media (max-width: 640px) {
    .service-row.slide-from-left:not(.revealed),
    .service-row.slide-from-right:not(.revealed) {
      transform: translate3d(0, 30px, 0);
    }
  }

  /* Disable motion for users who prefer reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .service-row {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }

  /* Disable hover lift on touch devices */
  @media (hover: none) {
    .service-row:hover .service-image-card {
      transform: none;
      box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.2);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const rows = document.querySelectorAll<HTMLElement>('.service-row');
    if (!rows.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const row = entry.target as HTMLElement;
            const index = parseInt(row.dataset.index || '0', 10);
            setTimeout(() => {
              row.classList.add('revealed');
            }, index * 150);
            observer.unobserve(row);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -50px 0px' }
    );

    rows.forEach((row) => observer.observe(row));
  });
</script>
