---
/**
 * WaveTransition — SVG wave divider between hero and next section.
 * Uses blue-to-light gradient: #0089D0 → #F5F7FA
 * Negative margin overlaps the hero bottom for a seamless transition.
 */
---

<div class="wave-transition" aria-hidden="true">
  <svg
    class="wave-svg"
    viewBox="0 0 1440 180"
    preserveAspectRatio="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <linearGradient id="wave-gradient" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#006BA3" stop-opacity="1" />
        <stop offset="35%" stop-color="#0089D0" stop-opacity="1" />
        <stop offset="100%" stop-color="#F5F7FA" stop-opacity="1" />
      </linearGradient>
    </defs>

    <!-- Back wave layer (subtle) -->
    <path
      d="M0,60 C240,120 480,20 720,80 C960,140 1200,40 1440,90 L1440,180 L0,180 Z"
      fill="#F5F7FA"
      opacity="0.4"
    />

    <!-- Middle wave layer -->
    <path
      d="M0,90 C180,130 360,50 600,90 C840,130 1080,60 1440,100 L1440,180 L0,180 Z"
      fill="#F5F7FA"
      opacity="0.6"
    />

    <!-- Front wave layer (main) -->
    <path
      d="M0,110 C320,150 480,80 720,110 C960,140 1200,90 1440,120 L1440,180 L0,180 Z"
      fill="#F5F7FA"
    />
  </svg>
</div>

<style>
  .wave-transition {
    position: relative;
    z-index: 2;
    margin-top: -120px;
    line-height: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .wave-svg {
    display: block;
    width: 100%;
    height: 120px;
  }

  @media (min-width: 768px) {
    .wave-transition {
      margin-top: -160px;
    }

    .wave-svg {
      height: 160px;
    }
  }

  @media (min-width: 1024px) {
    .wave-transition {
      margin-top: -180px;
    }

    .wave-svg {
      height: 180px;
    }
  }
</style>
