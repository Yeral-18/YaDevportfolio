---
import Layout from '@layouts/Layout.astro';
import Navbar from '@components/Navbar.astro';
import Hero from '@components/Hero.svelte';
import AboutUs from '@components/AboutUs.astro';
import Services from '@components/Services.astro';
import Benefits from '@components/Benefits.astro';
import Clients from '@components/Clients.astro';
import Contact from '@components/Contact.svelte';
import Footer from '@components/Footer.astro';
import WhatsAppButton from '@components/WhatsAppButton.svelte';
import ProgressBar from '@components/ProgressBar.svelte';
import ScrollToTop from '@components/ScrollToTop.svelte';
import GearCursor from '@components/GearCursor.svelte';
---

<Layout
  title="MULTISERVICIOS P&J S.A.S | Transporte de Carga, Obras Civiles y Remediación Ambiental en Barrancabermeja, Santander"
  description="Transporte de carga, obras civiles, remediación ambiental e izaje en Barrancabermeja, Santander. Empresa certificada ISO 9001, 14001, 45001. Cotice ahora."
>
  <ProgressBar client:load />

  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] focus:rounded-lg focus:bg-primary focus:px-4 focus:py-2 focus:text-white focus:outline-none focus:ring-2 focus:ring-accent"
  >
    Ir al contenido principal
  </a>

  <Navbar />

  <main id="main-content">
    <Hero client:load />
    <AboutUs />
    <Services />
    <Benefits />
    <Clients />
    <Contact client:visible />
  </main>

  <Footer />
  <ScrollToTop client:idle />
  <WhatsAppButton client:idle />
  <GearCursor client:idle />

  <!-- YaDev Internal: temporary panel -->
  <div id="yadev-panel" style="position:fixed;left:0;top:50%;transform:translateY(-50%);z-index:9999;display:flex;flex-direction:column;gap:0;">
    <button id="yadev-toggle" style="width:28px;height:72px;background:#1a1a2e;border:none;border-radius:0 8px 8px 0;cursor:pointer;display:flex;align-items:center;justify-content:center;opacity:0.4;transition:opacity .2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.4'">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
    </button>
    <div id="yadev-menu" style="display:none;background:#1a1a2e;border-radius:0 12px 12px 0;padding:12px;min-width:180px;box-shadow:0 8px 32px rgba(0,0,0,0.3);">
      <div style="font-size:9px;font-weight:700;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:0.15em;padding:0 8px 8px;border-bottom:1px solid rgba(255,255,255,0.08);margin-bottom:8px;">YaDev Internal</div>
      <a href={`${import.meta.env.BASE_URL}internal/brandbook.html`} target="_blank" style="display:flex;align-items:center;gap:8px;padding:8px;border-radius:6px;text-decoration:none;color:rgba(255,255,255,0.7);font-size:12px;font-weight:500;transition:all .15s;" onmouseover="this.style.background='rgba(255,255,255,0.08)';this.style.color='white'" onmouseout="this.style.background='transparent';this.style.color='rgba(255,255,255,0.7)'">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        Brandbook
      </a>
      <a href={`${import.meta.env.BASE_URL}internal/firma-correo.html`} target="_blank" style="display:flex;align-items:center;gap:8px;padding:8px;border-radius:6px;text-decoration:none;color:rgba(255,255,255,0.7);font-size:12px;font-weight:500;transition:all .15s;" onmouseover="this.style.background='rgba(255,255,255,0.08)';this.style.color='white'" onmouseout="this.style.background='transparent';this.style.color='rgba(255,255,255,0.7)'">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        Firma de Correo
      </a>
    </div>
  </div>
  <script is:inline>
    document.getElementById('yadev-toggle').addEventListener('click', () => {
      const menu = document.getElementById('yadev-menu');
      const btn = document.getElementById('yadev-toggle');
      const open = menu.style.display === 'none';
      menu.style.display = open ? 'block' : 'none';
      btn.style.borderRadius = open ? '0 8px 0 0' : '0 8px 8px 0';
    });
  </script>
</Layout>
