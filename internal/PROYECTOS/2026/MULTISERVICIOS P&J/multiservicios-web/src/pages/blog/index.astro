---
import Layout from '../../layouts/Layout.astro';

const posts: Array<{ slug: string; title: string; excerpt: string; publishedAt: string }> = [];
---

<Layout title="Blog | Multiservicios P&J S.A.S" description="Artículos y novedades de Multiservicios P&J sobre transporte de carga, obras civiles, remediación ambiental y energías renovables en Colombia.">
  <Fragment slot="head">
    <!-- noindex: activate blog indexing only when client approves content -->
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>

  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:rounded">
    Ir al contenido
  </a>

  <main id="main-content" class="blog-index">
    <div class="container">
      <h1>Blog</h1>
      <p class="subtitle">Novedades, artículos técnicos y actualizaciones de Multiservicios P&J S.A.S.</p>

      {posts.length === 0 ? (
        <p class="empty">Aún no tenemos publicaciones. Pronto compartiremos novedades sobre transporte, obras civiles y gestión ambiental.</p>
      ) : (
        <ul class="post-list">
          {posts.map(post => (
            <li>
              <a href={`/blog/${post.slug}`}>
                <h2>{post.title}</h2>
                <p>{post.excerpt}</p>
                <time>{post.publishedAt}</time>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </main>
</Layout>

<style>
  .blog-index {
    padding: 64px 0 80px;
  }

  .blog-index .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .blog-index h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 12px;
  }

  .subtitle {
    color: #555;
    margin-bottom: 48px;
    font-size: 1.125rem;
  }

  .empty {
    color: #666;
    padding: 40px 0;
    font-size: 1rem;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 24px;
  }

  .post-list a {
    display: block;
    padding: 24px;
    background: #f5f5f5;
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .post-list a:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .post-list h2 {
    font-size: 1.25rem;
    margin: 0 0 8px;
  }

  .post-list p {
    color: #555;
    margin: 0 0 12px;
    font-size: 0.9375rem;
  }

  .post-list time {
    font-size: 0.8125rem;
    color: #888;
  }
</style>
